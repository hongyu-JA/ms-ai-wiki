# Secrets
.env
.env.local
*.pem

# Claude Code lokaler Zustand — pro Entwickler, nicht teilen
.claude/settings.local.json

# Claude Code worktrees — jedes hat eigenen .git-Link, der Ordner selbst soll
# nicht im Haupt-Repo auftauchen
.claude/worktrees/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# Bun (wir verwenden npm im CI, package-lock.json ist massgeblich)
bun.lockb
bun.lock
# Ausnahme: web/ verwendet Bun als Build-Tool, Lockfile muss für reproduzierbare Cloudflare-Builds versioniert sein
!web/bun.lock
!web/bun.lockb

# Build / tmp
dist/
*.tsbuildinfo
.cache/

# Transient pipeline artefacts (der State selbst wird committet, die
# ephemeren raw/filtered/patches-Dateien nicht).
.automation/state/raw-items.json
.automation/state/filtered-items.json
.automation/state/patches.json

# SharePoint-Sync-Log (Skript schreibt jeden Lauf an, lokal-only)
.automation/state/sharepoint-sync.log

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Obsidian workspace-spezifisch (die Vault-Inhalte bleiben, nur User-State raus)
MS_AI_Wiki/.obsidian/workspace*.json
MS_AI_Wiki/.obsidian/appearance.json
MS_AI_Wiki/.obsidian/graph.json
